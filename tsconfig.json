{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext"],
    "types": ["node"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
    },

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "typeRoots": ["./node_modules/@types", "./src/types"],
  },

  "include": [
    "src/**/*",
    "src/types/express.d.ts"
  ]
}
